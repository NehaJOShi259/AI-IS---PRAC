#include <iostream>
using namespace std;

int main() {
    char str[] = "Hello World";

    cout << "Original String: " << str << endl;

    cout << "\nAfter AND with 127 (ASCII values): ";
    for (int i = 0; str[i] != '\0'; i++) {
        int result = str[i] & 127;
        cout << result << " ";
    }

    cout << "\nAfter XOR with 127 (ASCII values): ";
    for (int i = 0; str[i] != '\0'; i++) {
        int result = str[i] ^ 127;
        cout << result << " ";
    }

    cout << endl;
    return 0;
}

