#include <iostream>
#include <vector>
#include <queue>
using namespace std;

typedef pair<int,int> pii;

int main() {

    int V = 5;
    vector<pii> adj[5];

    adj[0].push_back({1,10});
    adj[0].push_back({3,5});
    adj[1].push_back({2,1});
    adj[3].push_back({1,3});
    adj[3].push_back({2,9});
    adj[3].push_back({4,2});
    adj[4].push_back({2,6});
    adj[4].push_back({0,7});

    priority_queue<pii, vector<pii>, greater<pii>> pq;
    vector<int> dist(V, 1e9);

    dist[0] = 0;
    pq.push({0,0});

    while(!pq.empty()) {
        int d = pq.top().first;
        int u = pq.top().second;
        pq.pop();

        for(auto x : adj[u]) {
            int v = x.first;
            int weight = x.second;

            if(dist[v] > d + weight) {
                dist[v] = d + weight;
                pq.push({dist[v], v});
            }
        }
    }

    cout << "Shortest distances from source 0:\n";
    for(int i=0;i<V;i++)
        cout << i << " : " << dist[i] << endl;

    return 0;
}
