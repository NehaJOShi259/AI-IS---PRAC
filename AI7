#include <iostream>
#include <algorithm>
using namespace std;

struct Edge {
    int u, v, weight;
};

bool compare(Edge a, Edge b) {
    return a.weight < b.weight;
}

int parent[100];

int find(int i) {
    if (parent[i] == i)
        return i;
    return parent[i] = find(parent[i]);
}

void unionSet(int u, int v) {
    parent[find(u)] = find(v);
}

int main() {

    int V = 4, E = 5;
    Edge edges[] = {
        {0,1,10},
        {0,2,6},
        {0,3,5},
        {1,3,15},
        {2,3,4}
    };

    sort(edges, edges + E, compare);

    for(int i = 0; i < V; i++)
        parent[i] = i;

    int totalCost = 0;

    cout << "Edges in MST:\n";

    for(int i = 0; i < E; i++) {
        int u = edges[i].u;
        int v = edges[i].v;

        if(find(u) != find(v)) {
            cout << u << " - " << v << " : " << edges[i].weight << endl;
            totalCost += edges[i].weight;
            unionSet(u, v);
        }
    }

    cout << "Total Cost: " << totalCost;

    return 0;
}


