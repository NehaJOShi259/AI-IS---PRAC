#include <iostream>
#include <algorithm>
using namespace std;

struct Job {
    char id;
    int deadline;
    int profit;
};

bool compare(Job a, Job b) {
    return a.profit > b.profit;
}

int main() {

    Job jobs[] = {
        {'A', 2, 100},
        {'B', 1, 19},
        {'C', 2, 27},
        {'D', 1, 25},
        {'E', 3, 15}
    };

    int n = sizeof(jobs)/sizeof(jobs[0]);

    sort(jobs, jobs + n, compare);

    int maxDeadline = 3;
    char result[3];
    bool slot[3] = {false};

    for(int i = 0; i < n; i++) {
        for(int j = jobs[i].deadline - 1; j >= 0; j--) {
            if(!slot[j]) {
                result[j] = jobs[i].id;
                slot[j] = true;
                break;
            }
        }
    }

    cout << "Selected Jobs: ";
    for(int i = 0; i < maxDeadline; i++)
        if(slot[i])
            cout << result[i] << " ";

    return 0;
}


