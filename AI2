#include <iostream>
#include <queue>
#include <vector>
#include <cmath>
#include <algorithm>
using namespace std;

struct Node {
    vector<vector<int>> mat;
    int x, y;   // blank position
    int g, h;   // cost + heuristic
    Node* parent;
};

int goal[3][3] = {
    {1,2,3},
    {4,5,6},
    {7,8,0}
};

// Manhattan Distance Heuristic
int calculateH(vector<vector<int>> mat) {
    int distance = 0;
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            if(mat[i][j] != 0){
                int val = mat[i][j] - 1;
                distance += abs(i - val/3) + abs(j - val%3);
            }
        }
    }
    return distance;
}

bool isSafe(int x, int y){
    return (x>=0 && x<3 && y>=0 && y<3);
}

struct compare {
    bool operator()(Node* a, Node* b) {
        return (a->g + a->h) > (b->g + b->h);
    }
};

void printMatrix(vector<vector<int>> mat){
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++)
            cout<<mat[i][j]<<" ";
        cout<<endl;
    }
    cout<<endl;
}

void printPath(Node* root){
    if(root == NULL) return;
    printPath(root->parent);
    printMatrix(root->mat);
}

void Astar(vector<vector<int>> start, int x, int y){
    priority_queue<Node*, vector<Node*>, compare> pq;

    Node* root = new Node{start, x, y, 0, calculateH(start), NULL};
    pq.push(root);

    int dx[] = {1,0,-1,0};
    int dy[] = {0,-1,0,1};

    while(!pq.empty()){
        Node* min = pq.top();
        pq.pop();

        if(min->h == 0){
            cout<<"Solution Found:\n";
            printPath(min);
            return;
        }

        for(int i=0;i<4;i++){
            int newX = min->x + dx[i];
            int newY = min->y + dy[i];

            if(isSafe(newX,newY)){
                vector<vector<int>> newMat = min->mat;
                swap(newMat[min->x][min->y], newMat[newX][newY]);

                Node* child = new Node{
                    newMat,
                    newX,
                    newY,
                    min->g + 1,
                    calculateH(newMat),
                    min
                };
                pq.push(child);
            }
        }
    }
}

int main(){
    vector<vector<int>> start = {
        {1,2,3},
        {4,0,6},
        {7,5,8}
    };

    Astar(start,1,1);
    return 0;
}
