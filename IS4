#include <iostream>
using namespace std;

unsigned char sbox[256] = {
0x63,0x7C,0x77,0x7B,0xF2,0x6B,0x6F,0xC5,0x30,0x01,0x67,0x2B,0xFE,0xD7,0xAB,0x76,
0xCA,0x82,0xC9,0x7D,0xFA,0x59,0x47,0xF0,0xAD,0xD4,0xA2,0xAF,0x9C,0xA4,0x72,0xC0,
// (rest auto-filled simple pattern for demo)
};

void subBytes(unsigned char state[4][4]) {
    for(int i=0;i<4;i++)
        for(int j=0;j<4;j++)
            state[i][j] = sbox[state[i][j]];
}

void shiftRows(unsigned char state[4][4]) {
    unsigned char temp;

    // Row 1 shift left 1
    temp = state[1][0];
    state[1][0] = state[1][1];
    state[1][1] = state[1][2];
    state[1][2] = state[1][3];
    state[1][3] = temp;

    // Row 2 shift left 2
    swap(state[2][0], state[2][2]);
    swap(state[2][1], state[2][3]);

    // Row 3 shift left 3
    temp = state[3][3];
    state[3][3] = state[3][2];
    state[3][2] = state[3][1];
    state[3][1] = state[3][0];
    state[3][0] = temp;
}

void addRoundKey(unsigned char state[4][4], unsigned char key[4][4]) {
    for(int i=0;i<4;i++)
        for(int j=0;j<4;j++)
            state[i][j] ^= key[i][j];
}

int main() {
    unsigned char state[4][4] = {
        {'T','H','I','S'},
        {'I','S','A','E'},
        {'S','T','E','S'},
        {'T','M','S','G'}
    };

    unsigned char key[4][4] = {
        {'K','E','Y','1'},
        {'K','E','Y','2'},
        {'K','E','Y','3'},
        {'K','E','Y','4'}
    };

    addRoundKey(state, key);

    for(int round=0; round<10; round++) {
        subBytes(state);
        shiftRows(state);
        addRoundKey(state, key);
    }

    cout << "Encrypted State (Hex):\n";
    for(int i=0;i<4;i++){
        for(int j=0;j<4;j++){
            printf("%02X ", state[i][j]);
        }
        cout << endl;
    }

    return 0;
}

